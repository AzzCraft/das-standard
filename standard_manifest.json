  "conditionalRequirements": [
    {
      "ruleId": "l2_master_doc_requires_context_pack",
      "appliesTo": {
        "docType": "master_doc",
        "conformanceProfiles": [
          "L2"
        ]
      },
      "requires": {
        "linkedDocTypes": [
          "context_pack"
        ],
        "notes": "L2 projects keep a current Context Pack linked from the canonical Master Doc."
      }
    },
    {
      "ruleId": "headless_master_doc_requires_headless_surface_note",
      "appliesTo": {
        "docType": "master_doc",
        "interactionProfiles": [
          "headless"
        ]
      },
      "requires": {
        "linkedDocTypes": [
          "headless_surface_note"
        ],
        "notes": "A local-extension-declared equivalent is allowed only when it maps back to core doc type `headless_surface_note` in `local_extension_manifest.json`. A thin `UI_SPEC = N/A` pointer doc does not satisfy this requirement by itself."
      }
    },
    {
      "ruleId": "ui_projects_require_ui_spec",
      "appliesTo": {
        "docType": "master_doc",
        "interactionProfiles": [
          "standard_ui",
          "hfvi_canvas_webgl_game"
        ]
      },
      "requires": {
        "linkedDocTypes": [
          "ui_spec"
        ],
        "notes": "A local-extension-declared equivalent is allowed only when it maps back to core doc type `ui_spec` in `local_extension_manifest.json`."
      }
    },
    {
      "ruleId": "hfvi_projects_require_vis_appendix",
      "appliesTo": {
        "docType": "master_doc",
        "interactionProfiles": [
          "hfvi_canvas_webgl_game"
        ]
      },
      "requires": {
        "artifactRefs": [
          "appendixK"
        ],
        "notes": "HFVI projects adopt the VIS template and HFVI verification model."
      }
    },
    {
      "ruleId": "worker_service_module_docs_require_interaction_profile",
      "appliesTo": {
        "docType": "module_doc",
        "moduleKinds": [
          "worker",
          "service"
        ]
      },
      "requires": {
        "metadataFields": [
          "Interaction profile"
        ],
        "notes": "Worker/service module docs declare the applicable interaction profile explicitly; use `headless` when there is no primary end-user UI."
      }
    },
    {
      "ruleId": "master_doc_requires_canonical_entrypoint_role",
      "appliesTo": {
        "docType": "master_doc"
      },
      "requires": {
        "metadataValues": {
          "Doc family role": [
            "canonical_entrypoint"
          ]
        },
        "notes": "Canonical Master Docs use doc-family role `canonical_entrypoint`."
      }
    },
    {
      "ruleId": "module_doc_requires_module_doc_role",
      "appliesTo": {
        "docType": "module_doc"
      },
      "requires": {
        "metadataValues": {
          "Doc family role": [
            "module_doc"
          ]
        },
        "notes": "Module docs use doc-family role `module_doc`."
      }
    },
    {
      "ruleId": "ui_spec_requires_non_headless_interaction_profile",
      "appliesTo": {
        "docType": "ui_spec"
      },
      "requires": {
        "metadataValues": {
          "Interaction profile": [
            "standard_ui",
            "hfvi_canvas_webgl_game"
          ]
        },
        "notes": "UI Spec docs are only for UI-bearing interaction profiles."
      }
    },
    {
      "ruleId": "headless_surface_note_requires_headless_interaction_profile",
      "appliesTo": {
        "docType": "headless_surface_note"
      },
      "requires": {
        "metadataValues": {
          "Interaction profile": [
            "headless"
          ]
        },
        "notes": "Headless Surface Notes use interaction profile `headless`."
      }
    },
    {
      "ruleId": "normative_addendum_requires_subordinate_role",
      "appliesTo": {
        "docType": "normative_addendum"
      },
      "requires": {
        "metadataValues": {
          "Doc family role": [
            "subordinate_doc"
          ]
        },
        "notes": "Normative addenda are governed subordinate companion docs to the main standard."
      }
    }
  ],
