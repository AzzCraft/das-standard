  "gateCadenceDefinitions": {
    "pr_blocking": {
      "summary": "Explicit correctness failures that must not merge.",
      "typicalUse": [
        "placeholder residue",
        "invalid status enum",
        "missing governing standard",
        "contract validation",
        "workflow fail-open lint",
        "tooling lock validation"
      ]
    },
    "merge_to_main": {
      "summary": "Continuous aggregate audits that may be too wide for every PR but still need regular enforcement.",
      "typicalUse": [
        "inventory sync reports",
        "package-doc completeness audits",
        "route/build/release drift summaries"
      ]
    },
    "nightly": {
      "summary": "Slow, deep, or trend-oriented checks.",
      "typicalUse": [
        "full trace graph builds",
        "deep contract completeness audits",
        "full AI eval suites",
        "broken-link scans",
        "regression dashboards"
      ]
    },
    "pre_release": {
      "summary": "Release-surface parity and closure checks required before promotion.",
      "typicalUse": [
        "docker/build-context parity",
        "release-lane status checks",
        "full contract mirror sync",
        "suite version closure",
        "release-pack verification"
      ]
    },
    "adoption_migration": {
      "summary": "Migration-only checks used when onboarding legacy repos or upgrading standards/tooling.",
      "typicalUse": [
        "adopt-existing-repo",
        "repo-normalize",
        "upgrade-standard",
        "contract-slice"
      ]
    }
  },
  "gateEnforcementDefinitions": {
    "report_only": {
      "summary": "Emits diagnostics but does not block merge/release."
    },
    "blocking": {
      "summary": "Blocks the cadence it is assigned to when failing."
    },
    "source_of_truth": {
      "summary": "Produces authoritative artifacts/inventories that other checks consume as trusted inputs."
    }
  },
  "sectionValueEnumBindings": {
    "module_doc": {
      "Determinism": "determinismValues"
    }
  },
  "requiredSubsections": {
    "master_doc": {
      "Document Control": [
        "Metadata",
        "Doc readiness gate",
        "Versioning and change control",
        "Glossary and canonical terminology",
        "Traceability index"
      ]
    },
    "module_doc": {
      "Verify": [
        "Commands",
        "Expected outcomes"
      ]
    }
  },
  "repoRoleDefinitions": {
    "standard_repo": "Owns the standard text, shipped appendices, machine-readable standard artifacts, release snapshots, and adoption/migration maps.",
    "suite_repo": "Owns the multi-repo module graph, suite lock, locked sync, module-state reporting, and suite-level upgrade orchestration.",
    "factory_repo": "Owns scaffolds, repo mutation/adoption tooling, standard-diff, trace helpers, and repo-shape normalization.",
    "verify_runtime_repo": "Owns analyzers, policy runtime, report/scan/lock/doctor executors, replay/eval bridges, and verify-report emitters.",
    "policy_pack_repo": "Owns reusable policy packs consumed by a verify runtime.",
    "control_plane_repo": "Owns org-wide waivers, dashboards, approvals, and governance UI.",
    "enterprise_subtree_repo": "Owns proprietary enterprise-only datasets, eval assets, or modelops/training chains.",
    "product_repo": "Owns product code, product docs, product contracts, and product-local verify flows.",
    "monorepo_local_tooling": "Owns topology-specific repo-local guards that are not yet generic enough to upstream."
  },
  "toolClassDefinitions": {
    "repo_audit": "Audits repo shape, docs, contracts, and topology for conformance.",
    "repo_mutation": "Changes repo state: create/init/adopt/repair/normalize.",
    "contract_validation": "Validates schemas, fixtures, IDs, references, and compatibility.",
    "verify_runtime": "Executes governed checks and emits machine-readable reports.",
    "policy_pack": "Supplies policy packs interpreted by a verify runtime.",
    "suite_orchestration": "Locks and orchestrates multi-repo suites/modules.",
    "control_plane": "Provides approvals, waivers, dashboards, or governance UX.",
    "enterprise_modelops": "Owns enterprise-only datasets/training/evals/modelops flows.",
    "monorepo_local_guard": "A topology-specific guard that should remain repo-local until generalized.",
    "migration_upgrade": "Upgrades standards, migrates repos, or slices contracts during adoption.",
    "other": "Other governed tooling class not covered above."
  },
  "toolPlacementDefinitions": {
    "standard_repo": "Standard manifests, release snapshots, adoption maps, migration maps.",
    "suite_repo": "Suite lock, module graph closure, locked sync, stale-pin detection, module-state reporting.",
    "factory_repo": "create/init/adopt/repair/standard-diff/contract-slice/repo-mutation tooling.",
    "verify_runtime_repo": "Analyzers, policy runtime, report/scan/lock/doctor executors, replay/eval bridges.",
    "policy_pack_repo": "Reusable policy packs and pack metadata.",
    "control_plane_repo": "Org-wide approvals, waivers, rollout dashboards, governance UI.",
    "enterprise_subtree_repo": "Enterprise-only datasets/evals/training/modelops assets.",
    "product_repo": "Product-specific code, contracts, docs, and local verify flows.",
    "monorepo_local_tooling": "Topology-specific parity/drift/scaffold guards for a given monorepo.",
    "repo_local_only": "Should remain local until at least two real consumers or a generalized abstraction exists."
  },
  "verifyGateKindDefinitions": {
    "docs_meta": "Doc metadata, required sections/subsections, placeholders, governing-standard presence.",
    "contracts": "Schema/fixture/identifier/OpenAPI compatibility and reference checks.",
    "unit": "Repo-local deterministic unit tests.",
    "assembly": "Boot/wiring/fail-fast checks.",
    "integration": "Cross-module integration tests inside a repo or service.",
    "api_e2e": "Mounted-host or public API end-to-end journeys.",
    "ui_e2e": "Browser/UI end-to-end smoke/staging flows.",
    "replay": "Replay, compare, restore, or deterministic evidence checks.",
    "eval": "AI/quality/eval thresholds and governed reports.",
    "drift_audit": "Topology or inventory drift scans typically run post-merge or nightly.",
    "migration_adoption": "Adoption, upgrade, standard-diff, or repo-normalization flows.",
    "other": "Other governed gate kind."
  },
  "moduleStateDefinitions": {
    "missing": "Expected by suite lock but not present locally.",
    "present_locked_match": "Present and matches the locked ref.",
    "present_locked_mismatch": "Present but does not match the locked ref.",
    "present_local_override": "Present under an explicit, governed local override.",
    "dirty": "Present with uncommitted or otherwise dirty local state."
  },
  "releaseSnapshotKindDefinitions": {
    "standard_release_bundle": "Canonical released snapshot of the DAS standard repo/bundle.",
    "factory_seed_snapshot": "Immutable snapshot used by a repo factory/template seed.",
