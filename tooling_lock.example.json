      "localModificationsAllowed": false,
      "snapshotRef": {
        "kind": "file",
        "uri": "./release_snapshot_manifest.example.json",
        "pinType": "manifest",
        "pinValue": "release_snapshot_manifest.example.json",
        "floating": false
      }
    }
  ]
