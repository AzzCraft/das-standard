{
  "$schema": "./tooling_lock.schema.json",
  "schemaVersion": "1.0.0",
  "standardManifestVersion": "1.4.6",
  "sourceOfTruth": {
    "kind": "git",
    "uri": "git@example.com:example-product-repo.git",
